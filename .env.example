# Grant System Configuration
# Copy this file to .env and fill in your actual values (never commit .env to git)

# Google Sheets Integration
# IMPORTANT: Download your service account JSON file and name it credentials.json
# OR update this path to match your actual filename
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_NAME=GrantWatch Grants

# Scraper Configuration
MAX_PAGES=3
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=6
HEADLESS_MODE=True

# Email Alert Configuration (OPTIONAL - only needed if using email alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
ALERT_SENDER_EMAIL=sender@example.com
ALERT_SENDER_PASSWORD=your_gmail_app_password_here
ALERT_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Eligibility Filters
# Format: comma-separated codes
# 25=Small businesses, 11=Nonprofits, 99=Individuals
ELIGIBILITY_CODES=25,11,99

# Status Filters
# Options: forecasted, posted
OPPORTUNITY_STATUSES=forecasted,posted

# Alert Threshold
# NOTE: Requires manual addition of "Relevance Score" column to spreadsheet
# Email alerts will be skipped if this column doesn't exist
RELEVANCE_SCORE_THRESHOLD=80

# Logging
LOG_LEVEL=INFO
LOG_FILE=grant_system.log
