# Grant System Configuration
# Copy this file to .env and fill in your actual values (never commit .env to git)

# Google Sheets Integration
# Path to your Google Service Account credentials JSON file
GOOGLE_CREDENTIALS_FILE=grantsgov-integration-298b73eb28d9.json
# Name of the Google Sheets spreadsheet
GOOGLE_SHEET_NAME=GrantWatch Grants
# Name of the worksheet/tab within the spreadsheet
GOOGLE_WORKSHEET_NAME=New_Grants_Imported

# Scraper Configuration
GRANTS_GOV_BASE_URL=https://www.grants.gov/search-grants
MAX_PAGES=3
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=6
HEADLESS_MODE=True

# Email Alert Configuration (Optional)
# Gmail SMTP server settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Your Gmail address (must enable "App Passwords" in Google Account settings)
ALERT_SENDER_EMAIL=your_email@gmail.com
# Gmail App Password (NOT your regular password - create at myaccount.google.com/apppasswords)
ALERT_SENDER_PASSWORD=your_app_password
# Comma-separated list of email recipients for alerts
ALERT_RECIPIENTS=shria@elevated-movements.com

# Eligibility Filters
# Format: comma-separated codes
# 25=Small businesses, 11=Nonprofits, 99=Individuals
ELIGIBILITY_CODES=25,11,99

# Status Filters
# forecasted, posted
OPPORTUNITY_STATUSES=forecasted,posted

# Alert Threshold
RELEVANCE_SCORE_THRESHOLD=80

# Logging
LOG_LEVEL=INFO
LOG_FILE=grant_system.log
